# Phase 5: メイン画面と処理の接続（進捗・キャンセル）

## ゴール

実行ボタン押下 → 進捗バー表示 → キャンセル可能 → 結果サマリ表示が動く状態。

-----

## 5.1 MainWindowViewModel の拡張

```csharp
// ViewModels/MainWindowViewModel.cs
using System.Collections.ObjectModel;
using Avalonia.Controls;
using Avalonia.Platform.Storage;
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using CsvTool.App.Models;
using CsvTool.App.Services;

namespace CsvTool.App.ViewModels;

public partial class MainWindowViewModel : ViewModelBase
{
    private readonly ICsvProcessor _csvProcessor;
    private CancellationTokenSource? _cts;

    public MainWindowViewModel(ICsvProcessor csvProcessor)
    {
        _csvProcessor = csvProcessor;
    }

    // --- 基本プロパティ ---

    [ObservableProperty]
    private string _title = "CSV分類ツール v0.1";

    [ObservableProperty]
    private string _inputPath = string.Empty;

    [ObservableProperty]
    private string _outputPath = string.Empty;

    [ObservableProperty]
    private string _statusText = "準備完了";

    // --- プリセット（Phase 6 まではハードコード） ---

    [ObservableProperty]
    private string _selectedPresetName = "2026Q1 売上データ分類";

    [ObservableProperty]
    private string _presetDescription = "月次売上CSVから削除済みを除外し、地域別に分割";

    // ハードコードのフィルタ（Phase 6 でプリセットから取得に変更）
    private readonly List<FilterRule> _currentFilters = new()
    {
        new FilterRule("status", FilterOp.Equals, "削除済み"),
        new FilterRule("amount", FilterOp.LessThan, "0"),
    };
    private string _categoryColumn = "category";
    private string _outputPattern = "data_{category}.csv";

    // --- 実行状態 ---

    [ObservableProperty]
    private bool _isRunning;

    [ObservableProperty]
    private int _progressPercent;

    [ObservableProperty]
    private string _progressText = string.Empty;

    [ObservableProperty]
    private ProcessResult? _lastResult;

    [ObservableProperty]
    private ObservableCollection<LogEntry> _logEntries = new();

    // --- CanExecute ---

    public bool CanExecute =>
        !string.IsNullOrWhiteSpace(InputPath) &&
        !string.IsNullOrWhiteSpace(OutputPath) &&
        !IsRunning;

    partial void OnInputPathChanged(string value)
    {
        ExecuteCommand.NotifyCanExecuteChanged();
    }
    partial void OnOutputPathChanged(string value)
    {
        ExecuteCommand.NotifyCanExecuteChanged();
    }
    partial void OnIsRunningChanged(bool value)
    {
        ExecuteCommand.NotifyCanExecuteChanged();
        CancelCommand.NotifyCanExecuteChanged();
    }

    // --- コマンド ---

    [RelayCommand]
    private async Task BrowseInputFile(Window window)
    {
        var result = await window.StorageProvider.OpenFilePickerAsync(
            new FilePickerOpenOptions
            {
                Title = "入力CSVファイルを選択",
                AllowMultiple = false,
                FileTypeFilter = new[]
                {
                    new FilePickerFileType("CSVファイル")
                        { Patterns = new[] { "*.csv" } },
                    FilePickerFileTypes.All
                }
            });

        if (result.Count > 0)
            InputPath = result[0].Path.LocalPath;
    }

    [RelayCommand]
    private async Task BrowseOutputFolder(Window window)
    {
        var result = await window.StorageProvider.OpenFolderPickerAsync(
            new FolderPickerOpenOptions
            {
                Title = "出力先フォルダを選択",
                AllowMultiple = false
            });

        if (result.Count > 0)
            OutputPath = result[0].Path.LocalPath;
    }

    [RelayCommand(CanExecute = nameof(CanExecute))]
    private async Task Execute()
    {
        IsRunning = true;
        ProgressPercent = 0;
        ProgressText = string.Empty;
        LastResult = null;
        LogEntries.Clear();

        AddLog("処理を開始しました");
        AddLog($"入力: {InputPath}");
        AddLog($"出力先: {OutputPath}");

        _cts = new CancellationTokenSource();

        var request = new ProcessRequest(
            InputPath: InputPath,
            OutputDir: OutputPath,
            CategoryColumn: _categoryColumn,
            Filters: _currentFilters,
            OutputFileNamePattern: _outputPattern);

        // IProgress<T> は SynchronizationContext を自動キャプチャする
        var progress = new Progress<ProgressInfo>(info =>
        {
            if (info.TotalRows > 0)
                ProgressPercent = (int)((long)info.ProcessedRows * 100
                    / info.TotalRows);
            ProgressText = info.Message;
        });

        try
        {
            var result = await _csvProcessor.ProcessAsync(
                request, progress, _cts.Token);

            LastResult = result;
            AddLog($"完了: {result.OutputRows:#,0}行出力 / " +
                   $"{result.FilteredRows:#,0}行除外 " +
                   $"({result.Elapsed.TotalSeconds:F1}秒)", "success");
            StatusText = $"処理完了 ({result.Elapsed.TotalSeconds:F1}秒)";
        }
        catch (OperationCanceledException)
        {
            AddLog("処理がキャンセルされました", "warning");
            StatusText = "キャンセル済み";
        }
        catch (Exception ex)
        {
            AddLog($"エラー: {ex.Message}", "error");
            StatusText = "エラーが発生しました";
        }
        finally
        {
            IsRunning = false;
            _cts?.Dispose();
            _cts = null;
        }
    }

    [RelayCommand]
    private void Cancel()
    {
        _cts?.Cancel();
        AddLog("キャンセルを要求しました...");
    }

    // --- ヘルパー ---

    private void AddLog(string message, string type = "info")
    {
        LogEntries.Add(new LogEntry(
            DateTime.Now.ToString("HH:mm:ss"),
            message,
            type));
    }
}

// ログエントリ
public record LogEntry(string Time, string Message, string Type);
```


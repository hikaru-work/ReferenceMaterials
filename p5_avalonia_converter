## 5.2 メイン画面 AXAML に進捗・結果・ログを追加

Phase 3 の AXAML に以下のセクションを **実行ボタンの下** に追加:

```xml
<!-- 進捗バー -->
<Border IsVisible="{Binding IsRunning}"
        Background="#EFF6FF"
        BorderBrush="#BFDBFE"
        BorderThickness="1"
        CornerRadius="8"
        Padding="16">
    <StackPanel Spacing="8">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding ProgressText}"
                       FontSize="12"
                       Foreground="#525252" />
            <TextBlock Grid.Column="1"
                       Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                       FontSize="12"
                       Foreground="#525252" />
        </Grid>
        <ProgressBar Value="{Binding ProgressPercent}"
                     Maximum="100"
                     Height="8" />
        <Button Content="キャンセル"
                Command="{Binding CancelCommand}"
                HorizontalAlignment="Right"
                Padding="12,4"
                FontSize="12" />
    </StackPanel>
</Border>

<!-- 結果サマリ -->
<Border IsVisible="{Binding LastResult, Converter={x:Static ObjectConverters.IsNotNull}}"
        Background="#F0FDF4"
        BorderBrush="#BBF7D0"
        BorderThickness="1"
        CornerRadius="8"
        Padding="16">
    <StackPanel Spacing="8">
        <TextBlock Text="処理結果"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Foreground="#166534" />
        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
            <!-- 入力 -->
            <Border Background="White" CornerRadius="4" Padding="8" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="入力" FontSize="11" Foreground="#737373" />
                    <TextBlock Text="{Binding LastResult.TotalRows, StringFormat='{}{0:#,0}'}"
                               FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <!-- 除外 -->
            <Border Grid.Column="1" Background="White" CornerRadius="4"
                    Padding="8" Margin="2,0">
                <StackPanel>
                    <TextBlock Text="除外" FontSize="11" Foreground="#737373" />
                    <TextBlock Text="{Binding LastResult.FilteredRows, StringFormat='{}{0:#,0}'}"
                               FontSize="18" FontWeight="SemiBold" Foreground="#DC2626" />
                </StackPanel>
            </Border>
            <!-- 出力 -->
            <Border Grid.Column="2" Background="White" CornerRadius="4"
                    Padding="8" Margin="4,0,0,0">
                <StackPanel>
                    <TextBlock Text="出力" FontSize="11" Foreground="#737373" />
                    <TextBlock Text="{Binding LastResult.OutputRows, StringFormat='{}{0:#,0}'}"
                               FontSize="18" FontWeight="SemiBold" Foreground="#166534" />
                </StackPanel>
            </Border>
        </Grid>
        <!-- 分類別結果は ItemsControl で表示 -->
        <ItemsControl ItemsSource="{Binding LastResult.Categories}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:CategoryResult">
                    <Border Background="White" CornerRadius="4"
                            Padding="8,4" Margin="0,4,4,0"
                            BorderBrush="#BBF7D0" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding CategoryName}"
                                       FontWeight="SemiBold" FontSize="12" />
                            <TextBlock Text="{Binding RowCount, StringFormat='{}{0:#,0}行'}"
                                       FontSize="12" Foreground="#737373" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</Border>

<!-- ログ -->
<Border IsVisible="{Binding LogEntries.Count}"
        Background="#171717"
        CornerRadius="8"
        Padding="12"
        Height="140">
    <ScrollViewer>
        <ItemsControl ItemsSource="{Binding LogEntries}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:LogEntry">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Time}"
                                   FontFamily="Consolas,monospace"
                                   FontSize="11"
                                   Foreground="#737373" />
                        <TextBlock Text="{Binding Message}"
                                   FontFamily="Consolas,monospace"
                                   FontSize="11"
                                   Foreground="#D4D4D4" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Border>

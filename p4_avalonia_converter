## 4.2 フィルタ判定ロジック

```csharp
// Services/FilterEvaluator.cs
using CsvTool.App.Models;

namespace CsvTool.App.Services;

public static class FilterEvaluator
{
    /// <summary>
    /// いずれかのフィルタに一致する場合 true（= 除外対象）
    /// </summary>
    public static bool ShouldExclude(
        IReadOnlyList<FilterRule> filters,
        Func<string, string> getColumnValue)
    {
        foreach (var filter in filters)
        {
            var value = getColumnValue(filter.Column);
            if (Matches(filter, value))
                return true;
        }
        return false;
    }

    private static bool Matches(FilterRule filter, string cellValue)
    {
        return filter.Op switch
        {
            FilterOp.Equals      => string.Equals(cellValue, filter.Value,
                                        StringComparison.Ordinal),
            FilterOp.NotEquals   => !string.Equals(cellValue, filter.Value,
                                        StringComparison.Ordinal),
            FilterOp.Contains    => cellValue.Contains(filter.Value,
                                        StringComparison.Ordinal),
            FilterOp.NotContains => !cellValue.Contains(filter.Value,
                                        StringComparison.Ordinal),
            FilterOp.LessThan   => double.TryParse(cellValue, out var num)
                                   && double.TryParse(filter.Value, out var threshold)
                                   && num < threshold,
            FilterOp.IsEmpty     => string.IsNullOrWhiteSpace(cellValue),
            _ => false
        };
    }
}
```


## 4.3 CSV プロセッサ本体

```csharp
// Services/ICsvProcessor.cs
using CsvTool.App.Models;

namespace CsvTool.App.Services;

public interface ICsvProcessor
{
    Task<ProcessResult> ProcessAsync(
        ProcessRequest request,
        IProgress<ProgressInfo>? progress = null,
        CancellationToken cancellationToken = default);
}
```

```csharp
// Services/CsvProcessor.cs
using System.Diagnostics;
using System.Text;
using CsvTool.App.Models;
using nietras.SeparatedValues; // Sep の名前空間

namespace CsvTool.App.Services;

public class CsvProcessor : ICsvProcessor
{
    // 進捗通知の間引き間隔
    private const int ProgressReportInterval = 5000;

    public async Task<ProcessResult> ProcessAsync(
        ProcessRequest request,
        IProgress<ProgressInfo>? progress = null,
        CancellationToken cancellationToken = default)
    {
        return await Task.Run(() =>
            ProcessCore(request, progress, cancellationToken),
            cancellationToken);
    }

    private ProcessResult ProcessCore(
        ProcessRequest request,
        IProgress<ProgressInfo>? progress,
        CancellationToken cancellationToken)
    {
        var sw = Stopwatch.StartNew();

        // 出力先フォルダ作成
        Directory.CreateDirectory(request.OutputDir);

        // 入力ファイルの総行数を事前カウント（進捗計算用）
        var totalRows = CountLines(request.InputPath) - 1; // ヘッダー除く
        progress?.Report(new ProgressInfo(0, totalRows,
            $"総行数: {totalRows:#,0}"));

        // Sep で読み込み
        using var reader = Sep.Reader().FromFile(request.InputPath);

        // ヘッダー取得
        var header = reader.Header;
        var headerLine = string.Join(",",
            Enumerable.Range(0, header.ColNames.Count)
                .Select(i => header.ColNames[i]));

        // 分類列のインデックスを事前取得
        var categoryColIndex = header.IndexOf(request.CategoryColumn);

        // カテゴリ別のライター管理
        var writers = new Dictionary<string, StreamWriter>();
        var categoryCounts = new Dictionary<string, int>();

        var processedRows = 0;
        var filteredRows = 0;

        try
        {
            foreach (var row in reader)
            {
                cancellationToken.ThrowIfCancellationRequested();

                processedRows++;

                // フィルタ判定
                if (FilterEvaluator.ShouldExclude(request.Filters,
                    col => row[col].ToString()))
                {
                    filteredRows++;
                    ReportProgress(progress, processedRows, totalRows);
                    continue;
                }

                // カテゴリ取得
                var category = row[categoryColIndex].ToString();
                if (string.IsNullOrEmpty(category))
                    category = "_empty";

                // ライターを取得 or 新規作成
                if (!writers.TryGetValue(category, out var writer))
                {
                    var fileName = request.OutputFileNamePattern
                        .Replace("{category}", SanitizeFileName(category));
                    var filePath = Path.Combine(request.OutputDir, fileName);

                    writer = new StreamWriter(filePath, false, Encoding.UTF8);
                    writer.WriteLine(headerLine);
                    writers[category] = writer;
                    categoryCounts[category] = 0;
                }

                // 行を書き出し
                var line = string.Join(",",
                    Enumerable.Range(0, header.ColNames.Count)
                        .Select(i => EscapeCsvField(row[i].ToString())));
                writer.WriteLine(line);
                categoryCounts[category]++;

                ReportProgress(progress, processedRows, totalRows);
            }
        }
        finally
        {
            // すべてのライターを確実に閉じる
            foreach (var writer in writers.Values)
            {
                writer.Dispose();
            }
        }

        sw.Stop();

        // 結果を組み立て
        var categories = categoryCounts
            .OrderByDescending(kv => kv.Value)
            .Select(kv => new CategoryResult(
                kv.Key,
                kv.Value,
                Path.Combine(request.OutputDir,
                    request.OutputFileNamePattern
                        .Replace("{category}", SanitizeFileName(kv.Key)))))
            .ToList();

        return new ProcessResult(
            TotalRows: processedRows,
            FilteredRows: filteredRows,
            OutputRows: processedRows - filteredRows,
            Categories: categories,
            Elapsed: sw.Elapsed);
    }

    private void ReportProgress(
        IProgress<ProgressInfo>? progress,
        int processedRows,
        int totalRows)
    {
        if (progress == null) return;
        if (processedRows % ProgressReportInterval != 0
            && processedRows != totalRows) return;

        progress.Report(new ProgressInfo(
            processedRows, totalRows,
            $"{processedRows:#,0} / {totalRows:#,0} 行処理済み"));
    }

    private static int CountLines(string filePath)
    {
        var count = 0;
        using var reader = new StreamReader(filePath);
        while (reader.ReadLine() != null) count++;
        return count;
    }

    private static string SanitizeFileName(string name)
    {
        var invalid = Path.GetInvalidFileNameChars();
        return string.Concat(name.Select(c =>
            invalid.Contains(c) ? '_' : c));
    }

    private static string EscapeCsvField(string field)
    {
        if (field.Contains(',') || field.Contains('"')
            || field.Contains('\n') || field.Contains('\r'))
        {
            return $"\"{field.Replace("\"", "\"\"")}\"";
        }
        return field;
    }
}
```


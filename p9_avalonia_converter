## 9.4 インポートプレビュー ViewModel

```csharp
// ViewModels/ImportPreviewViewModel.cs
using System.Collections.ObjectModel;
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using CsvTool.App.Models;

namespace CsvTool.App.ViewModels;

public enum ConflictResolution
{
    Add,       // 新規追加（重複なし）
    Rename,    // 名前変更して追加
    Overwrite, // 上書き
    Skip       // スキップ
}

public partial class ImportItemViewModel : ViewModelBase
{
    public Preset Preset { get; }
    public bool HasConflict { get; }

    [ObservableProperty]
    private ConflictResolution _resolution;

    public ImportItemViewModel(Preset preset, bool hasConflict)
    {
        Preset = preset;
        HasConflict = hasConflict;
        Resolution = hasConflict ? ConflictResolution.Rename : ConflictResolution.Add;
    }
}

public partial class ImportPreviewViewModel : ViewModelBase
{
    [ObservableProperty]
    private ObservableCollection<ImportItemViewModel> _items = new();

    [ObservableProperty]
    private ObservableCollection<string> _warnings = new();

    [ObservableProperty]
    private bool _hasVersionWarning;

    [ObservableProperty]
    private string _versionWarningText = string.Empty;

    public bool HasConflicts => Items.Any(i => i.HasConflict);

    public void Load(
        ImportPreview preview,
        IReadOnlyList<Preset> existingPresets)
    {
        var existingNames = existingPresets
            .Select(p => p.Name)
            .ToHashSet();

        Items = new ObservableCollection<ImportItemViewModel>(
            preview.Presets.Select(p =>
                new ImportItemViewModel(p, existingNames.Contains(p.Name))));

        Warnings = new ObservableCollection<string>(preview.Warnings);

        if (preview.HasVersionWarning)
        {
            HasVersionWarning = true;
            VersionWarningText =
                $"スキーマ v{preview.FileSchemaVersion} のプリセットが" +
                "含まれています。一部の設定が無視される可能性があります。";
        }
    }

    /// <summary>
    /// 確定。競合解決を適用したプリセット一覧を返す。
    /// </summary>
    public List<(Preset Preset, ConflictResolution Resolution)> GetResolvedPresets()
    {
        return Items
            .Where(i => i.Resolution != ConflictResolution.Skip)
            .Select(i => (i.Preset, i.Resolution))
            .ToList();
    }
}

## 9.6 インポート確定処理

管理画面のコードビハインドに追加:

```csharp
// PresetManagementWindow.axaml.cs
// ImportButton.Click イベント内で呼ぶ

private void ApplyImport(
    ImportPreviewViewModel previewVm,
    IPresetRepository repo,
    IReadOnlyList<Preset> existingPresets)
{
    var existingByName = existingPresets
        .ToDictionary(p => p.Name, p => p);

    foreach (var (preset, resolution) in previewVm.GetResolvedPresets())
    {
        switch (resolution)
        {
            case ConflictResolution.Add:
                repo.Save(preset);
                break;

            case ConflictResolution.Rename:
                var newName = preset.Name;
                var n = 2;
                while (existingByName.ContainsKey(newName)
                    || newName == preset.Name && n > 2)
                {
                    newName = $"{preset.Name} ({n++})";
                }
                preset.Name = newName;
                repo.Save(preset);
                break;

            case ConflictResolution.Overwrite:
                if (existingByName.TryGetValue(preset.Name, out var existing))
                {
                    preset.Id = existing.Id; // 既存 ID を引き継ぐ
                }
                repo.Save(preset);
                break;

            case ConflictResolution.Skip:
                break;
        }
    }
}

// Services/IPresetExchangeService.cs
using CsvTool.App.Models;

namespace CsvTool.App.Services;

public interface IPresetExchangeService
{
    /// <summary>
    /// プリセットを JSON ファイルにエクスポート
    /// </summary>
    Task ExportAsync(IReadOnlyList<Preset> presets, string filePath);

    /// <summary>
    /// JSON または ZIP からプリセットを読み込む（検証のみ、保存しない）
    /// </summary>
    Task<ImportPreview> ImportPreviewAsync(string filePath);
}

public class ImportPreview
{
    public List<Preset> Presets { get; set; } = new();
    public List<string> Warnings { get; set; } = new();
    public bool HasVersionWarning { get; set; }
    public int FileSchemaVersion { get; set; }
}
```

```csharp
// Services/PresetExchangeService.cs
using System.IO.Compression;
using System.Text.Json;
using System.Text.Json.Serialization;
using CsvTool.App.Models;

namespace CsvTool.App.Services;

public class PresetExchangeService : IPresetExchangeService
{
    private const int CurrentSchemaVersion = 1;

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        WriteIndented = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter() }
    };

    public async Task ExportAsync(
        IReadOnlyList<Preset> presets, string filePath)
    {
        if (filePath.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
        {
            await ExportAsZipAsync(presets, filePath);
        }
        else
        {
            await ExportAsJsonAsync(presets, filePath);
        }
    }

    private async Task ExportAsJsonAsync(
        IReadOnlyList<Preset> presets, string filePath)
    {
        var data = new PresetExportData
        {
            SchemaVersion = CurrentSchemaVersion,
            ExportedAt = DateTime.Now,
            Presets = presets.Select(StripId).ToList()
        };

        var json = JsonSerializer.Serialize(data, JsonOptions);
        await File.WriteAllTextAsync(filePath, json);
    }

    private async Task ExportAsZipAsync(
        IReadOnlyList<Preset> presets, string filePath)
    {
        using var stream = File.Create(filePath);
        using var archive = new ZipArchive(stream, ZipArchiveMode.Create);

        foreach (var preset in presets)
        {
            var data = new PresetExportData
            {
                SchemaVersion = CurrentSchemaVersion,
                ExportedAt = DateTime.Now,
                Presets = new List<Preset> { StripId(preset) }
            };

            var json = JsonSerializer.Serialize(data, JsonOptions);
            var safeFileName = SanitizeFileName(preset.Name) + ".json";
            var entry = archive.CreateEntry(safeFileName);

            using var writer = new StreamWriter(entry.Open());
            await writer.WriteAsync(json);
        }
    }

    public async Task<ImportPreview> ImportPreviewAsync(string filePath)
    {
        var preview = new ImportPreview();

        if (filePath.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
        {
            await ImportFromZipAsync(filePath, preview);
        }
        else
        {
            await ImportFromJsonAsync(filePath, preview);
        }

        return preview;
    }

    private async Task ImportFromJsonAsync(
        string filePath, ImportPreview preview)
    {
        var json = await File.ReadAllTextAsync(filePath);
        var data = JsonSerializer.Deserialize<PresetExportData>(
            json, JsonOptions);

        if (data == null)
        {
            preview.Warnings.Add("ファイルの読み込みに失敗しました");
            return;
        }

        CheckVersion(data.SchemaVersion, preview);

        foreach (var preset in data.Presets)
        {
            ValidatePreset(preset, preview);
            preset.Id = Guid.NewGuid().ToString("N")[..8]; // 新しいIDを付与
            preview.Presets.Add(preset);
        }
    }

    private async Task ImportFromZipAsync(
        string filePath, ImportPreview preview)
    {
        using var stream = File.OpenRead(filePath);
        using var archive = new ZipArchive(stream, ZipArchiveMode.Read);

        foreach (var entry in archive.Entries
            .Where(e => e.Name.EndsWith(".json",
                StringComparison.OrdinalIgnoreCase)))
        {
            try
            {
                using var reader = new StreamReader(entry.Open());
                var json = await reader.ReadToEndAsync();
                var data = JsonSerializer.Deserialize<PresetExportData>(
                    json, JsonOptions);

                if (data?.Presets == null) continue;

                CheckVersion(data.SchemaVersion, preview);

                foreach (var preset in data.Presets)
                {
                    ValidatePreset(preset, preview);
                    preset.Id = Guid.NewGuid().ToString("N")[..8];
                    preview.Presets.Add(preset);
                }
            }
            catch (JsonException)
            {
                preview.Warnings.Add(
                    $"ファイル '{entry.Name}' の読み込みに失敗しました");
            }
        }
    }

    private static void CheckVersion(
        int fileVersion, ImportPreview preview)
    {
        if (fileVersion > CurrentSchemaVersion)
        {
            preview.HasVersionWarning = true;
            preview.FileSchemaVersion = fileVersion;
            preview.Warnings.Add(
                $"スキーマ v{fileVersion} は現在の v{CurrentSchemaVersion} " +
                "より新しいため、一部の設定が無視される可能性があります");
        }
    }

    private static void ValidatePreset(
        Preset preset, ImportPreview preview)
    {
        if (string.IsNullOrWhiteSpace(preset.Name))
        {
            preset.Name = "（名前なし）";
            preview.Warnings.Add("名前が空のプリセットがあります");
        }
    }

    private static Preset StripId(Preset p) => new()
    {
        SchemaVersion = p.SchemaVersion,
        Name = p.Name,
        Description = p.Description,
        CategoryColumn = p.CategoryColumn,
        Filters = p.Filters,
        OutputFileNamePattern = p.OutputFileNamePattern,
        CreatedAt = p.CreatedAt,
        UpdatedAt = p.UpdatedAt,
    };

    private static string SanitizeFileName(string name)
    {
        var invalid = Path.GetInvalidFileNameChars();
        return string.Concat(name.Select(c =>
            invalid.Contains(c) ? '_' : c));
    }
}

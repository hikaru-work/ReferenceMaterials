## 9.7 管理画面のインポート/エクスポートボタン接続

```csharp
// PresetManagementWindow.axaml.cs に追加

// エクスポートボタン
ExportButton.Click += async (_, _) =>
{
    if (DataContext is not PresetManagementViewModel vm) return;
    if (vm.SelectedPresets.Count == 0) return;

    var exchange = App.Services
        .GetRequiredService<IPresetExchangeService>();

    var isSingle = vm.SelectedPresets.Count == 1;
    var defaultName = isSingle
        ? $"{vm.SelectedPresets[0].Name}.json"
        : $"presets_{DateTime.Now:yyyy-MM-dd}.zip";

    var result = await StorageProvider.SaveFilePickerAsync(
        new FilePickerSaveOptions
        {
            Title = "プリセットのエクスポート",
            SuggestedFileName = defaultName,
            FileTypeChoices = new[]
            {
                new FilePickerFileType("JSON")
                    { Patterns = new[] { "*.json" } },
                new FilePickerFileType("ZIP")
                    { Patterns = new[] { "*.zip" } },
            }
        });

    if (result == null) return;

    await exchange.ExportAsync(
        vm.SelectedPresets.ToList(),
        result.Path.LocalPath);

    // 成功通知（簡易）
    // MessageBox やステータスバーで通知
};

// インポートボタン
ImportButton.Click += async (_, _) =>
{
    var exchange = App.Services
        .GetRequiredService<IPresetExchangeService>();
    var repo = App.Services
        .GetRequiredService<IPresetRepository>();

    var files = await StorageProvider.OpenFilePickerAsync(
        new FilePickerOpenOptions
        {
            Title = "プリセットのインポート",
            AllowMultiple = false,
            FileTypeFilter = new[]
            {
                new FilePickerFileType("プリセットファイル")
                    { Patterns = new[] { "*.json", "*.zip" } },
            }
        });

    if (files.Count == 0) return;

    var preview = await exchange.ImportPreviewAsync(
        files[0].Path.LocalPath);

    if (preview.Presets.Count == 0)
    {
        // エラー通知
        return;
    }

    // プレビュー画面を開く
    var previewVm = new ImportPreviewViewModel();
    previewVm.Load(preview, repo.GetAll());

    var previewWindow = new ImportPreviewWindow
        { DataContext = previewVm };
    var confirmed = await previewWindow.ShowDialog<bool>(this);

    if (confirmed)
    {
        ApplyImport(previewVm, repo, repo.GetAll());

        if (DataContext is PresetManagementViewModel vm)
            vm.LoadPresets();
    }
};

# Phase 7: プリセット管理画面

## ゴール

モーダルウィンドウでプリセットの一覧表示・複製・削除ができる状態。
編集（新規作成含む）は Phase 8 で実装するため、ボタンだけ配置しておく。

-----

## 7.1 管理画面の ViewModel

```csharp
// ViewModels/PresetManagementViewModel.cs
using System.Collections.ObjectModel;
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using CsvTool.App.Models;
using CsvTool.App.Services;

namespace CsvTool.App.ViewModels;

public partial class PresetManagementViewModel : ViewModelBase
{
    private readonly IPresetRepository _presetRepository;

    public PresetManagementViewModel(IPresetRepository presetRepository)
    {
        _presetRepository = presetRepository;
        LoadPresets();
    }

    [ObservableProperty]
    private ObservableCollection<Preset> _presets = new();

    [ObservableProperty]
    private Preset? _selectedPreset;

    [ObservableProperty]
    private ObservableCollection<Preset> _selectedPresets = new();

    // 選択件数に応じたボタン制御
    public bool CanDuplicate => SelectedPresets.Count == 1;
    public bool CanEdit => SelectedPresets.Count == 1;
    public bool CanDelete => SelectedPresets.Count > 0;
    public bool CanExport => SelectedPresets.Count > 0;

    // 選択変更時にボタン有効/無効を再評価
    public void NotifySelectionChanged()
    {
        OnPropertyChanged(nameof(CanDuplicate));
        OnPropertyChanged(nameof(CanEdit));
        OnPropertyChanged(nameof(CanDelete));
        OnPropertyChanged(nameof(CanExport));
        DuplicateCommand.NotifyCanExecuteChanged();
        DeleteCommand.NotifyCanExecuteChanged();
    }

    public string SelectionInfo =>
        $"{SelectedPresets.Count}件選択中 / 全{Presets.Count}件";

    // --- コマンド ---

    [RelayCommand(CanExecute = nameof(CanDuplicate))]
    private void Duplicate()
    {
        if (SelectedPresets.Count != 1) return;
        var original = SelectedPresets[0];

        var copy = new Preset
        {
            Name = $"{original.Name} のコピー",
            Description = original.Description,
            CategoryColumn = original.CategoryColumn,
            Filters = original.Filters
                .Select(f => new FilterRule(f.Column, f.Op, f.Value))
                .ToList(),
            OutputFileNamePattern = original.OutputFileNamePattern,
        };

        _presetRepository.Save(copy);
        LoadPresets();
    }

    [RelayCommand(CanExecute = nameof(CanDelete))]
    private void Delete()
    {
        // 確認は View 側で実施してからこのコマンドを呼ぶ
        foreach (var preset in SelectedPresets.ToList())
        {
            _presetRepository.Delete(preset.Id);
        }
        LoadPresets();
    }

    /// <summary>
    /// 編集完了後にリスト更新するために公開
    /// </summary>
    public void LoadPresets()
    {
        _presetRepository.Reload();
        Presets = new ObservableCollection<Preset>(
            _presetRepository.GetAll());
        SelectedPresets.Clear();
        NotifySelectionChanged();
        OnPropertyChanged(nameof(SelectionInfo));
    }
}
```


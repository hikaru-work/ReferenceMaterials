## 7.2 管理画面の View（AXAML）

```xml
<!-- Views/PresetManagementWindow.axaml -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CsvTool.App.ViewModels"
        xmlns:models="using:CsvTool.App.Models"
        x:Class="CsvTool.App.Views.PresetManagementWindow"
        x:DataType="vm:PresetManagementViewModel"
        Title="プリセット管理"
        Width="750" Height="500"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <DockPanel Margin="16">

        <!-- 上部: ツールバー -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Spacing="6"
                    Margin="0,0,0,12">
            <!-- 新規は Phase 8 で実装 -->
            <Button Content="新規" Padding="10,5" />
            <Button Content="複製"
                    Command="{Binding DuplicateCommand}"
                    Padding="10,5" />
            <Button Content="編集" Padding="10,5" />
            <!-- Phase 8 で接続 -->
            <Button Content="削除"
                    Command="{Binding DeleteCommand}"
                    Padding="10,5" />

            <!-- スペーサ -->
            <Border Width="1" Background="#E5E5E5"
                    Margin="8,2" />

            <!-- Phase 9 で接続 -->
            <Button Content="インポート" Padding="10,5" />
            <Button Content="エクスポート" Padding="10,5" />
        </StackPanel>

        <!-- 下部: ステータス + 閉じるボタン -->
        <Grid DockPanel.Dock="Bottom"
              ColumnDefinitions="*,Auto"
              Margin="0,12,0,0">
            <TextBlock Text="{Binding SelectionInfo}"
                       FontSize="12"
                       Foreground="#737373"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Content="閉じる"
                    Padding="16,6"
                    Name="CloseButton" />
        </Grid>

        <!-- 中央: プリセット一覧 -->
        <DataGrid ItemsSource="{Binding Presets}"
                  SelectedItem="{Binding SelectedPreset}"
                  SelectionMode="Extended"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#E5E5E5"
                  BorderThickness="1"
                  CornerRadius="4"
                  Name="PresetGrid">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名前"
                                    Binding="{Binding Name}"
                                    Width="200" />
                <DataGridTextColumn Header="説明"
                                    Binding="{Binding Description}"
                                    Width="*" />
                <DataGridTextColumn Header="Ver"
                                    Binding="{Binding SchemaVersion,
                                        StringFormat='v{0}'}"
                                    Width="50" />
                <DataGridTextColumn Header="更新日"
                                    Binding="{Binding UpdatedAt,
                                        StringFormat='{}{0:yyyy-MM-dd}'}"
                                    Width="100" />
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>

</Window>
```


# Phase 8: プリセット編集画面

## ゴール

プリセットの新規作成・既存編集が GUI で完結する状態。
除外条件の動的追加・削除を含む。

-----

## 8.1 編集画面の ViewModel

```csharp
// ViewModels/PresetEditorViewModel.cs
using System.Collections.ObjectModel;
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using CsvTool.App.Models;

namespace CsvTool.App.ViewModels;

public partial class PresetEditorViewModel : ViewModelBase
{
    private readonly Preset? _original; // null = 新規作成

    public PresetEditorViewModel(Preset? preset = null)
    {
        _original = preset;
        IsNewPreset = preset == null;
        WindowTitle = IsNewPreset ? "プリセット新規作成" : "プリセット編集";

        if (preset != null)
        {
            Name = preset.Name;
            Description = preset.Description;
            CategoryColumn = preset.CategoryColumn;
            OutputFileNamePattern = preset.OutputFileNamePattern;
            Filters = new ObservableCollection<FilterRuleViewModel>(
                preset.Filters.Select(f => new FilterRuleViewModel(f)));
        }
    }

    public bool IsNewPreset { get; }
    public string WindowTitle { get; }

    // 保存結果（View 側で取得する）
    public Preset? Result { get; private set; }

    // --- 編集対象プロパティ ---

    [ObservableProperty]
    private string _name = string.Empty;

    [ObservableProperty]
    private string _description = string.Empty;

    [ObservableProperty]
    private string _categoryColumn = string.Empty;

    [ObservableProperty]
    private string _outputFileNamePattern = "output_{category}.csv";

    [ObservableProperty]
    private ObservableCollection<FilterRuleViewModel> _filters = new();

    // --- バリデーション ---

    [ObservableProperty]
    private string _nameError = string.Empty;

    public bool HasErrors => !string.IsNullOrEmpty(NameError);

    partial void OnNameChanged(string value)
    {
        NameError = string.IsNullOrWhiteSpace(value)
            ? "名前は必須です"
            : string.Empty;
        SaveCommand.NotifyCanExecuteChanged();
    }

    public bool CanSave =>
        !string.IsNullOrWhiteSpace(Name);

    // --- コマンド ---

    [RelayCommand]
    private void AddFilter()
    {
        Filters.Add(new FilterRuleViewModel(
            new FilterRule("", FilterOp.Equals, "")));
    }

    [RelayCommand]
    private void RemoveFilter(FilterRuleViewModel filter)
    {
        Filters.Remove(filter);
    }

    [RelayCommand(CanExecute = nameof(CanSave))]
    private void Save()
    {
        Result = new Preset
        {
            Id = _original?.Id ?? Guid.NewGuid().ToString("N")[..8],
            SchemaVersion = _original?.SchemaVersion ?? 1,
            Name = Name.Trim(),
            Description = Description.Trim(),
            CategoryColumn = CategoryColumn.Trim(),
            OutputFileNamePattern = OutputFileNamePattern.Trim(),
            Filters = Filters
                .Select(f => new FilterRule(f.Column, f.Op, f.Value))
                .ToList(),
            CreatedAt = _original?.CreatedAt ?? DateTime.Now,
            UpdatedAt = DateTime.Now,
        };

        // View 側で Close を呼ぶ（Result が non-null なら保存成功）
    }
}
```


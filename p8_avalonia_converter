## 8.3 編集画面の View（AXAML）

```xml
<!-- Views/PresetEditorWindow.axaml -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CsvTool.App.ViewModels"
        x:Class="CsvTool.App.Views.PresetEditorWindow"
        x:DataType="vm:PresetEditorViewModel"
        Title="{Binding WindowTitle}"
        Width="650" Height="550"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <DockPanel Margin="20">

        <!-- 下部: ボタン -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Content="キャンセル"
                    Padding="16,6"
                    Name="CancelButton" />
            <Button Content="保存"
                    Command="{Binding SaveCommand}"
                    Padding="16,6"
                    Background="#2563EB"
                    Foreground="White"
                    Name="SaveButton" />
        </StackPanel>

        <!-- メインフォーム -->
        <ScrollViewer>
            <StackPanel Spacing="12">

                <!-- 名前 -->
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <TextBlock Text="名前" FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="*" Foreground="#EF4444"
                                   FontSize="12" />
                    </StackPanel>
                    <TextBox Text="{Binding Name}"
                             Watermark="プリセットの名前を入力" />
                    <TextBlock Text="{Binding NameError}"
                               FontSize="11"
                               Foreground="#EF4444"
                               IsVisible="{Binding NameError,
                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>

                <!-- 説明 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="説明" FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBox Text="{Binding Description}"
                             Watermark="このプリセットの用途を記述"
                             AcceptsReturn="True"
                             Height="60"
                             TextWrapping="Wrap" />
                </StackPanel>

                <!-- 分類列 + 出力パターン -->
                <Grid ColumnDefinitions="*,16,*">
                    <StackPanel Spacing="4">
                        <TextBlock Text="分類列" FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBox Text="{Binding CategoryColumn}"
                                 Watermark="例: category" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="出力ファイル名パターン" FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBox Text="{Binding OutputFileNamePattern}"
                                 Watermark="例: output_{category}.csv"
                                 FontFamily="Consolas,monospace" />
                    </StackPanel>
                </Grid>

                <!-- パターン説明 -->
                <TextBlock Text="{}{category} は分類列の値に置換されます"
                           FontSize="11"
                           Foreground="#A3A3A3"
                           Margin="0,-8,0,0" />

                <!-- 除外条件 -->
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="除外条件"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="+ 追加"
                                Command="{Binding AddFilterCommand}"
                                Padding="10,4"
                                FontSize="12" />
                    </Grid>

                    <!-- フィルタ一覧 -->
                    <ItemsControl ItemsSource="{Binding Filters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FilterRuleViewModel">
                                <Grid ColumnDefinitions="*,Auto,*,Auto"
                                      Margin="0,0,0,6">
                                    <!-- 列名 -->
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Column}"
                                             Watermark="列名"
                                             Margin="0,0,4,0" />
                                    <!-- 演算子 -->
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{x:Static vm:FilterRuleViewModel.AvailableOps}"
                                              SelectedValue="{Binding Op}"
                                              SelectedValueBinding="{Binding Value}"
                                              DisplayMemberBinding="{Binding DisplayName}"
                                              Width="120"
                                              Margin="0,0,4,0" />
                                    <!-- 値 -->
                                    <TextBox Grid.Column="2"
                                             Text="{Binding Value}"
                                             Watermark="値"
                                             Margin="0,0,4,0" />
                                    <!-- 削除 -->
                                    <Button Grid.Column="3"
                                            Content="✕"
                                            Command="{Binding #root.((vm:PresetEditorViewModel)DataContext).RemoveFilterCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="8,4"
                                            FontSize="11" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- フィルタが0件の場合 -->
                    <TextBlock Text="除外条件なし（すべての行を出力します）"
                               FontSize="12"
                               Foreground="#A3A3A3"
                               FontStyle="Italic"
                               IsVisible="{Binding !Filters.Count}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>

</Window>
```


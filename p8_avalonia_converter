## 8.2 FilterRuleViewModel

フィルタ条件 1 行分の ViewModel:

```csharp
// ViewModels/FilterRuleViewModel.cs
using CommunityToolkit.Mvvm.ComponentModel;
using CsvTool.App.Models;

namespace CsvTool.App.ViewModels;

public partial class FilterRuleViewModel : ViewModelBase
{
    public FilterRuleViewModel(FilterRule rule)
    {
        _column = rule.Column;
        _op = rule.Op;
        _value = rule.Value;
    }

    [ObservableProperty]
    private string _column;

    [ObservableProperty]
    private FilterOp _op;

    [ObservableProperty]
    private string _value;

    /// <summary>
    /// ComboBox の ItemsSource 用
    /// </summary>
    public static IReadOnlyList<FilterOpItem> AvailableOps { get; } = new[]
    {
        new FilterOpItem(FilterOp.Equals,      "等しい"),
        new FilterOpItem(FilterOp.NotEquals,    "等しくない"),
        new FilterOpItem(FilterOp.Contains,     "含む"),
        new FilterOpItem(FilterOp.NotContains,  "含まない"),
        new FilterOpItem(FilterOp.LessThan,     "未満"),
        new FilterOpItem(FilterOp.IsEmpty,      "空である"),
    };
}

public record FilterOpItem(FilterOp Value, string DisplayName);
```


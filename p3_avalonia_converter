                           Foreground="#737373" />
                <TextBlock Text="Avalonia UI 11.x · .NET 9"
                           FontSize="12"
                           Foreground="#A3A3A3"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- メインコンテンツ -->
        <ScrollViewer Padding="24">
            <StackPanel Spacing="16" MaxWidth="800">

                <!-- プリセット選択 -->
                <Border Background="#EFF6FF"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="変換プリセット"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <!-- Phase 6 で ComboBox に差し替え -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SelectedPresetName}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Padding="8,6"
                                       Background="White"
                                       BorderBrush="#D4D4D4"
                                       BorderThickness="1"
                                       CornerRadius="4" />
                            <Button Grid.Column="1"
                                    Content="管理..."
                                    Margin="8,0,0,0"
                                    Padding="12,6" />
                        </Grid>
                        <Border Background="White"
                                BorderBrush="#DBEAFE"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10">
                            <TextBlock Text="{Binding PresetDescription}"
                                       FontSize="12"
                                       Foreground="#737373" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 入力ファイル -->
                <StackPanel Spacing="4">
                    <TextBlock Text="入力ファイル"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding InputPath}"
                                 Watermark="CSVファイルのパスを入力、または参照..."
                                 FontSize="13" />
                        <Button Grid.Column="1"
                                Content="参照..."
                                Command="{Binding BrowseInputFileCommand}"
                                CommandParameter="{Binding $parent[Window]}"
                                Margin="8,0,0,0"
                                Padding="12,6" />
                    </Grid>
                </StackPanel>

                <!-- 出力先フォルダ -->
                <StackPanel Spacing="4">
                    <TextBlock Text="出力先フォルダ"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding OutputPath}"
                                 Watermark="出力先フォルダのパスを入力、または参照..."
                                 FontSize="13" />
                        <Button Grid.Column="1"
                                Content="参照..."

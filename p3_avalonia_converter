# Phase 3: メイン画面の UI（ファイル選択まで）

## ゴール

モックのメイン画面を AXAML で再現し、ファイル/フォルダ選択ダイアログが動作する状態。
処理はまだ動かない（ボタンを押しても何も起きない）。

-----

## 3.1 MainWindowViewModel を拡張

```csharp
// ViewModels/MainWindowViewModel.cs
using System.Collections.ObjectModel;
using Avalonia;
using Avalonia.Controls;
using Avalonia.Platform.Storage;
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;

namespace CsvTool.App.ViewModels;

public partial class MainWindowViewModel : ViewModelBase
{
    [ObservableProperty]
    private string _title = "CSV分類ツール v0.1";

    [ObservableProperty]
    private string _statusText = "準備完了";

    [ObservableProperty]
    private string _inputPath = string.Empty;

    [ObservableProperty]
    private string _outputPath = string.Empty;

    // プリセット（Phase 6 まではハードコード）
    [ObservableProperty]
    private string _selectedPresetName = "2026Q1 売上データ分類";

    [ObservableProperty]
    private string _presetDescription = "月次売上CSVから削除済みを除外し、地域別に分割";

    // 実行可否の判定
    public bool CanExecute =>
        !string.IsNullOrWhiteSpace(InputPath) &&
        !string.IsNullOrWhiteSpace(OutputPath);

    // プロパティ変更時に CanExecute を再評価
    partial void OnInputPathChanged(string value)
    {
        OnPropertyChanged(nameof(CanExecute));
        ExecuteCommand.NotifyCanExecuteChanged();
    }

    partial void OnOutputPathChanged(string value)
    {
        OnPropertyChanged(nameof(CanExecute));
        ExecuteCommand.NotifyCanExecuteChanged();
    }

    // --- コマンド ---

    // ファイル選択（View 側から Window 参照を渡す）
    [RelayCommand]
    private async Task BrowseInputFile(Window window)
    {
        var storageProvider = window.StorageProvider;
        var result = await storageProvider.OpenFilePickerAsync(new FilePickerOpenOptions
        {
            Title = "入力CSVファイルを選択",
            AllowMultiple = false,
            FileTypeFilter = new[]
            {
                new FilePickerFileType("CSVファイル")
                {
                    Patterns = new[] { "*.csv" }
                },
                FilePickerFileTypes.All
            }
        });

        if (result.Count > 0)
        {
            InputPath = result[0].Path.LocalPath;
        }
    }

    [RelayCommand]
    private async Task BrowseOutputFolder(Window window)
    {
        var storageProvider = window.StorageProvider;
        var result = await storageProvider.OpenFolderPickerAsync(new FolderPickerOpenOptions
        {
            Title = "出力先フォルダを選択",
            AllowMultiple = false
        });

        if (result.Count > 0)
        {
            OutputPath = result[0].Path.LocalPath;
        }
    }

    // 実行（Phase 5 で実装。今は空）
    [RelayCommand(CanExecute = nameof(CanExecute))]
    private async Task Execute()
    {
        StatusText = "処理を開始しました...（未実装）";
        await Task.Delay(1000);
        StatusText = "準備完了";
    }
}
```


## 6.7 MainWindowViewModel のプリセット対応

ハードコードのフィルタを削除し、プリセットから取得するように変更:

```csharp
// MainWindowViewModel.cs に追加・変更

private readonly IPresetRepository _presetRepository;

public MainWindowViewModel(
    ICsvProcessor csvProcessor,
    IPresetRepository presetRepository)
{
    _csvProcessor = csvProcessor;
    _presetRepository = presetRepository;
    LoadPresets();
}

// プリセット一覧
[ObservableProperty]
private ObservableCollection<Preset> _presets = new();

[ObservableProperty]
private Preset? _selectedPreset;

partial void OnSelectedPresetChanged(Preset? value)
{
    StatusText = value != null
        ? $"プリセット: {value.Name}"
        : "プリセット未選択";
}

private void LoadPresets()
{
    Presets = new ObservableCollection<Preset>(
        _presetRepository.GetAll());

    if (Presets.Count > 0)
        SelectedPreset = Presets[0];
}

// Execute コマンドの request 生成部分を変更
// （ハードコード → SelectedPreset から取得）
[RelayCommand(CanExecute = nameof(CanExecute))]
private async Task Execute()
{
    if (SelectedPreset == null) return;

    // ... 既存のコード ...

    var request = new ProcessRequest(
        InputPath: InputPath,
        OutputDir: OutputPath,
        CategoryColumn: SelectedPreset.CategoryColumn,
        Filters: SelectedPreset.Filters,
        OutputFileNamePattern: SelectedPreset.OutputFileNamePattern);

    // ... 既存の処理コード ...
}
```


## 6.3 プリセットリポジトリ

```csharp
// Services/IPresetRepository.cs
using CsvTool.App.Models;

namespace CsvTool.App.Services;

public interface IPresetRepository
{
    IReadOnlyList<Preset> GetAll();
    Preset? GetById(string id);
    void Save(Preset preset);
    void Delete(string id);
    void Reload();
}
```

```csharp
// Services/PresetRepository.cs
using System.Text.Json;
using System.Text.Json.Serialization;
using CsvTool.App.Models;

namespace CsvTool.App.Services;

public class PresetRepository : IPresetRepository
{
    private readonly string _presetsDir;
    private readonly List<Preset> _presets = new();

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        WriteIndented = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter() }
    };

    public PresetRepository()
    {
        var appData = Environment.GetFolderPath(
            Environment.SpecialFolder.ApplicationData);
        _presetsDir = Path.Combine(appData, "CsvTool", "presets");
        Directory.CreateDirectory(_presetsDir);
        Reload();
    }

    public IReadOnlyList<Preset> GetAll() => _presets.AsReadOnly();

    public Preset? GetById(string id) =>
        _presets.FirstOrDefault(p => p.Id == id);

    public void Save(Preset preset)
    {
        preset.UpdatedAt = DateTime.Now;
        var path = GetFilePath(preset.Id);
        var json = JsonSerializer.Serialize(preset, JsonOptions);
        File.WriteAllText(path, json);

        // メモリ上のリストも更新
        var idx = _presets.FindIndex(p => p.Id == preset.Id);
        if (idx >= 0)
            _presets[idx] = preset;
        else
            _presets.Add(preset);
    }

    public void Delete(string id)
    {
        var path = GetFilePath(id);
        if (File.Exists(path))
            File.Delete(path);

        _presets.RemoveAll(p => p.Id == id);
    }

    public void Reload()
    {
        _presets.Clear();

        if (!Directory.Exists(_presetsDir)) return;

        foreach (var file in Directory.GetFiles(_presetsDir, "*.json"))
        {
            try
            {
                var json = File.ReadAllText(file);
                var preset = JsonSerializer.Deserialize<Preset>(
                    json, JsonOptions);

                if (preset == null) continue;

                // スキーマバージョンチェック
                if (preset.SchemaVersion > 1)
                {
                    // 将来のバージョン。読み込むが警告を出す余地を残す
                }

                _presets.Add(preset);
            }
            catch (JsonException)
            {
                // 壊れたファイルはスキップ
            }
        }

        // 名前順にソート
        _presets.Sort((a, b) =>
            string.Compare(a.Name, b.Name, StringComparison.Ordinal));
    }

    private string GetFilePath(string id) =>
        Path.Combine(_presetsDir, $"{id}.json");
}
```


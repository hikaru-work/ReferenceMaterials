## 6.9 初回起動時のサンプルプリセット作成

プリセットが 0 件の場合にサンプルを自動生成:

```csharp
// PresetRepository.cs の Reload() の末尾に追加
if (_presets.Count == 0)
{
    CreateSamplePresets();
}

private void CreateSamplePresets()
{
    var sample = new Preset
    {
        Name = "サンプル: ステータス別分類",
        Description = "「削除済み」を除外し、カテゴリ列の値で分割するサンプル",
        CategoryColumn = "category",
        Filters = new List<FilterRule>
        {
            new("status", FilterOp.Equals, "削除済み")
        },
        OutputFileNamePattern = "data_{category}.csv"
    };
    Save(sample);
}
```


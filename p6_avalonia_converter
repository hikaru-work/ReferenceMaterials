## 6.8 メイン画面の AXAML 変更

プリセット表示部分を `ComboBox` に差し替える:

```xml
<!-- プリセット選択（Phase 3 の TextBlock を差し替え） -->
<Grid ColumnDefinitions="*,Auto">
    <ComboBox Grid.Column="0"
              ItemsSource="{Binding Presets}"
              SelectedItem="{Binding SelectedPreset}"
              FontSize="13"
              HorizontalAlignment="Stretch">
        <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="models:Preset">
                <TextBlock Text="{Binding Name}" />
            </DataTemplate>
        </ComboBox.ItemTemplate>
    </ComboBox>
    <Button Grid.Column="1"
            Content="管理..."
            Margin="8,0,0,0"
            Padding="12,6" />
</Grid>

<!-- プリセット詳細表示 -->
<Border Background="White"
        BorderBrush="#DBEAFE"
        BorderThickness="1"
        CornerRadius="4"
        Padding="10"
        IsVisible="{Binding SelectedPreset, Converter={x:Static ObjectConverters.IsNotNull}}">
    <StackPanel Spacing="4">
        <TextBlock Text="{Binding SelectedPreset.Description}"
                   FontSize="12"
                   Foreground="#737373" />
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock FontSize="11">
                <Run Text="分類列: " Foreground="#A3A3A3" />
                <Run Text="{Binding SelectedPreset.CategoryColumn}" />
            </TextBlock>
            <TextBlock FontSize="11">
                <Run Text="除外条件: " Foreground="#A3A3A3" />
                <Run Text="{Binding SelectedPreset.Filters.Count}" />
                <Run Text="件" />
            </TextBlock>
        </StackPanel>
    </StackPanel>
</Border>
```

